# VARIABLES DE ENTORNO PARA CONFIGURAR LA CONEXIÓN MQTT

# PROTOCOLO DEL BROKER:
# ws = WebSocket sin cifrado (desarrollo o broker local)
# wss = WebSocket seguro (SSL/TLS, recomendado para producción)
VITE_MQTT_PROTOCOL=YOUR_VITE_MQTT_PROTOCOL

# HOST DEL BROKER:
# Local: IP del dispositivo donde se ejecuta el broker (ej. 192.168.1.100)
# Público: dominio (ej. broker.hivemq.com, test.mosquitto.org)
VITE_MQTT_HOST=YOUR_VITE_MQTT_HOST

# PUERTO DEL BROKER:
# Eclipse Mosquitto local (ws): 9001
# Eclipse Mosquitto local (wss): 9002
# Públicos:
#   ws: 8080 / 8083
#   wss: 8081 / 8884 / 443 (depende del proveedor)
VITE_MQTT_PORT=YOUR_VITE_MQTT_PORT

# RUTA DEL WEBSOCKET (opcional):
# Algunos brokers requieren una ruta final (ej. /mqtt)
# Otros no la utilizan
VITE_MQTT_PATH=YOUR_VITE_MQTT_PATH

# NOTAS DE CONFIGURACIÓN:
# 1. En redes locales, la IP del broker puede cambiar (usa `ipconfig` o `hostname -I`).
# 2. En producción, usa siempre wss si está disponible.
# 3. Usa topics únicos para evitar colisiones en brokers públicos.
# 4. Este proyecto no contempla brokers con autenticación (usuario/contraseña).

# EJEMPLOS DE CONFIGURACIÓN:

# Caso A: Local (Mosquitto con WebSockets)
# VITE_MQTT_PROTOCOL=ws
# VITE_MQTT_HOST=192.168.1.100
# VITE_MQTT_PORT=9001
# VITE_MQTT_PATH=

# Caso B: Público (EMQX con WebSocket seguro)
# VITE_MQTT_PROTOCOL=wss
# VITE_MQTT_HOST=broker.emqx.io
# VITE_MQTT_PORT=8884
# VITE_MQTT_PATH=/mqtt

# Caso C: Público (Mosquitto test)
# VITE_MQTT_PROTOCOL=wss
# VITE_MQTT_HOST=test.mosquitto.org
# VITE_MQTT_PORT=8080
# VITE_MQTT_PATH=