# VARIABLES DE ENTORNO PARA CONFIGURAR LA CONEXIÓN MQTT

# PROTOCOLO DEL BRÓKER:
# - ws = WebSocket sin cifrado (ej. bróker local)
# - wss = WebSocket seguro
VITE_MQTT_PROTOCOL=YOUR_VITE_MQTT_PROTOCOL

# HOST DEL BRÓKER:
# - Entorno local (hotspot o router): usa la IP del dispositivo donde corre el bróker MQTT (ej. 172.20.10.2)
# - Entorno público: usa un dominio (ej. broker.hivemq.com)
VITE_MQTT_HOST=YOUR_VITE_MQTT_HOST

# PUERTO DEL BRÓKER:
# - Local (Mosquitto con WebSockets): 9001
# - Público:
#   - ws: 8083
#   - wss: 443, 8883 o 8884 (depende del proveedor)
VITE_MQTT_PORT=YOUR_VITE_MQTT_PORT

# PATH DEL WEBSOCKET (opcional):
# - Algunos brókers lo requieren (ej. /mqtt)
# - Otros lo dejan vacío
VITE_MQTT_PATH=YOUR_VITE_MQTT_PATH

# NOTAS DE CONFIGURACIÓN:
# 1. Si usas un bróker local, la IP puede cambiar (verifícala con ipconfig en Windows o hostname -I en Linux)
# 2. En brókers públicos o en producción, usa siempre wss si está disponible
# 3. Usa topics únicos para evitar colisiones en brókers públicos

# EJEMPLOS DE CONFIGURACIÓN:

# Caso A: local (Mosquitto en red local)
# VITE_MQTT_PROTOCOL=ws
# VITE_MQTT_HOST=172.20.10.2
# VITE_MQTT_PORT=9001
# VITE_MQTT_PATH=

# Caso B: público (HiveMQ)
# VITE_MQTT_PROTOCOL=wss
# VITE_MQTT_HOST=broker.hivemq.com
# VITE_MQTT_PORT=8884
# VITE_MQTT_PATH=/mqtt